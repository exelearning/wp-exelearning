msgid "Embedded Editor"
msgstr "Editor integrat"

msgid "The embedded editor is required to edit eXeLearning files."
msgstr "L'editor integrat és necessari per a editar fitxers eXeLearning."

msgid "Please install it using the button below."
msgstr "Per favor, instal·leu-lo amb el botó de baix."

msgid "Status:"
msgstr "Estat:"

msgid "Installed"
msgstr "Instal·lat"

msgid "Installed on:"
msgstr "Instal·lat el:"

msgid "Update to Latest Version"
msgstr "Actualitza a l'última versió"

msgid "Not installed"
msgstr "No instal·lat"

msgid "The embedded eXeLearning editor is not installed. You can download and install the latest version automatically from GitHub."
msgstr "L'editor integrat d'eXeLearning no està instal·lat. Podeu descarregar i instal·lar l'última versió automàticament des de GitHub."

msgid "Download & Install Editor"
msgstr "Descarrega i instal·la l'editor"

#. translators: %s: make build-editor command
#, php-format
msgid "Developers can also build the editor from source using %s."
msgstr "Els desenvolupadors també poden compilar l'editor des del codi font usant %s."

msgid "Try Again"
msgstr "Torna a intentar-ho"

msgid "Installing..."
msgstr "Instal·lant..."

msgid "Downloading and installing the editor. This may take a minute..."
msgstr "Descarregant i instal·lant l'editor. Açò pot tardar un minut..."

msgid "Open Editor"
msgstr "Obri l'editor"

msgid "Installation failed."
msgstr "La instal·lació ha fallat."

msgid "Network error. Please check your connection and try again."
msgstr "Error de xarxa. Per favor, comproveu la connexió i torneu a intentar-ho."

msgid "Security check failed. Please refresh the page and try again."
msgstr "La verificació de seguretat ha fallat. Per favor, recarregueu la pàgina i torneu a intentar-ho."

msgid "You do not have permission to install the editor."
msgstr "No teniu permís per a instal·lar l'editor."

msgid "An installation is already in progress. Please wait."
msgstr "Ja hi ha una instal·lació en curs. Per favor, espereu."

#. translators: %s: editor version
#, php-format
msgid "eXeLearning editor v%s installed successfully."
msgstr "Editor d'eXeLearning v%s instal·lat correctament."

#. translators: %s: error message
#, php-format
msgid "Could not connect to GitHub: %s"
msgstr "No s'ha pogut connectar a GitHub: %s"

#. translators: %d: HTTP status code
#, php-format
msgid "GitHub API returned status %d. Please try again later."
msgstr "L'API de GitHub ha retornat l'estat %d. Per favor, proveu-ho més tard."

msgid "Could not parse the latest release information from GitHub."
msgstr "No s'ha pogut analitzar la informació de l'última versió de GitHub."

#. translators: %s: tag name
#, php-format
msgid "Unexpected release tag format: %s"
msgstr "Format d'etiqueta de versió inesperat: %s"

#. translators: %s: error message
#, php-format
msgid "Failed to download the editor package: %s"
msgstr "Error en descarregar el paquet de l'editor: %s"

msgid "The downloaded file is not a valid ZIP archive."
msgstr "El fitxer descarregat no és un arxiu ZIP vàlid."

msgid "Could not create temporary directory for extraction."
msgstr "No s'ha pogut crear el directori temporal per a l'extracció."

#. translators: %s: error message
#, php-format
msgid "Failed to extract the editor package: %s"
msgstr "Error en extraure el paquet de l'editor: %s"

msgid "The downloaded package does not contain the expected editor files. Could not find index.html."
msgstr "El paquet descarregat no conté els fitxers esperats de l'editor. No s'ha trobat index.html."

msgid "The editor package is missing index.html."
msgstr "Al paquet de l'editor li falta index.html."

msgid "The editor package is missing expected asset directories (app, libs, or files)."
msgstr "Al paquet de l'editor li falten els directoris de recursos esperats (app, libs o files)."

msgid "Could not create the dist directory."
msgstr "No s'ha pogut crear el directori dist."

msgid "Could not back up the existing editor installation."
msgstr "No s'ha pogut fer una còpia de seguretat de la instal·lació actual de l'editor."

msgid "Failed to copy editor files to the plugin directory."
msgstr "Error en copiar els fitxers de l'editor al directori del connector."
