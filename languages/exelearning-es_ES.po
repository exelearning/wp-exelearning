msgstr "Subir archivo .elpx"

msgid "Media Library"
msgstr "Biblioteca de medios"

msgid "Height (px)"
msgstr "Altura (px)"

msgid "Show Teacher Mode toggler"
msgstr "Mostrar el conmutador de Modo Profesor"

msgid "Change file"
msgstr "Cambiar archivo"

msgid "Remove"
msgstr "Eliminar"

